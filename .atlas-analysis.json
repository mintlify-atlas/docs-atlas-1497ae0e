  "keyFeatures": [
    "User authentication with multiple strategies (password, magic links, remember me)",
    "Email confirmation workflow for new user registrations",
    "Password reset functionality with secure tokens",
    "JWT-based token authentication",
    "JSON:API compliant REST endpoints",
    "OpenAPI/Swagger documentation",
    "Built on Ash Framework for declarative resource management",
    "PostgreSQL data persistence with AshPostgres"
  ],
  "publicApiSurface": [
    "POST /api/json/auth/register - Register new user",
    "POST /api/json/auth/sign-in - Sign in with password",
    "POST /api/json/auth/sign-out - Sign out current user",
    "POST /api/json/auth/password-reset - Request password reset",
    "POST /api/json/auth/magic-link - Request magic link",
    "GET /api/json/users/:id - Get user by ID",
    "PATCH /api/json/users/:id/change-password - Change user password",
    "AshCoffee.Accounts.User - User resource with authentication",
    "AshCoffee.Accounts.Token - Token resource for authentication"
  ]
}
